<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <?define ProductName = "Prizrak-Box" ?>
  <?define Manufacturer = "legiz-ru" ?>
  <?define HelpLink = "https://github.com/legiz-ru/Prizrak-Box" ?>

  <Product Id="*"
           Name="$(var.ProductName)"
           Language="$(var.Language)"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">

    <Package Id="*"
             InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             InstallPrivileges="elevated"
             Platform="$(var.Platform)"
             Description="!(loc.PB_ProductDescription)"
             Manufacturer="$(var.Manufacturer)" />

    <!-- Require Windows 7 or higher -->
    <Condition Message="!(loc.PB_OSVersionError)">
      <![CDATA[Installed OR (VersionNT >= 601)]]>
    </Condition>

    <!-- Major Upgrade -->
    <MajorUpgrade DowngradeErrorMessage="!(loc.PB_NewerVersionInstalled)"
                  Schedule="afterInstallInitialize"
                  AllowSameVersionUpgrades="yes" />

    <?ifdef Wails ?>
    <!-- Supersede any previously installed Electron build. Every Electron
         package (electron-forge MakerWix from v1.0.20, installed to
         "Program Files (x86)\Prizrak-Box" with an app-<ver> subfolder, AND the
         later custom WiX MSI in "Program Files\Prizrak-Box") shares this
         UpgradeCode, so RemoveExistingProducts (scheduled by MajorUpgrade above)
         uninstalls whichever is present via its own cached MSI — cleaning its
         files, shortcuts and Add/Remove Programs entry regardless of x86/x64
         install path — before the Wails files are laid down. -->
    <Upgrade Id="$(var.ElectronUpgradeCode)">
      <UpgradeVersion Minimum="0.0.0" IncludeMinimum="yes"
                      Maximum="255.255.255" IncludeMaximum="yes"
                      OnlyDetect="no" MigrateFeatures="no" RemoveFeatures="ALL"
                      Property="LEGACYELECTRONFOUND" />
    </Upgrade>
    <?endif?>

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Icon for Add/Remove Programs - use dedicated .ico file instead of extracting from .exe -->
    <Icon Id="AppIcon" SourceFile="..\..\build\appicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="$(var.HelpLink)" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />
    <Property Id="ARPCOMMENTS" Value="Version $(var.FullVersion)" />

    <!-- Properties -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <Property Id="INSTALLTUNSERVICE" Value="1" />
    <Property Id="SELECTEDLANGUAGE" Value="$(var.Culture)" />

    <!-- Directory Structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="$(var.ProgramFilesFolder)">
        <Directory Id="INSTALLDIR" Name="$(var.ProductName)">
          <Directory Id="RESOURCESDIR" Name="resources" />
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="$(var.ProductName)" />
      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <!-- Protocol Handler and App Registration -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="AppRegistration" Guid="$(var.AppRegistrationGuid)" Win64="$(var.Win64)">
        <!-- Registry for Protocol Handler prizrak-box:// -->
        <RegistryKey Root="HKCR" Key="prizrak-box">
          <RegistryValue Type="string" Value="URL:Prizrak-Box Protocol" />
          <RegistryValue Type="string" Name="URL Protocol" Value="" />
          <RegistryKey Key="DefaultIcon">
            <RegistryValue Type="string" Value="[INSTALLDIR]Prizrak-Box.exe,0" />
          </RegistryKey>
          <RegistryKey Key="shell\open\command">
            <RegistryValue Type="string" Value='"[INSTALLDIR]Prizrak-Box.exe" "%1"' />
          </RegistryKey>
        </RegistryKey>

        <!-- Installation marker -->
        <RegistryValue Root="HKLM"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="InstallPath"
                       Type="string"
                       Value="[INSTALLDIR]"
                       KeyPath="yes" />

        <RegistryValue Root="HKLM"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="Version"
                       Type="string"
                       Value="$(var.ProductVersion)"
                       KeyPath="no" />
      </Component>
    </DirectoryRef>

    <!-- Desktop Shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="$(var.DesktopShortcutGuid)">
        <Shortcut Id="DesktopShortcut"
                  Name="$(var.ProductName)"
                  Description="!(loc.PB_ProductDescription)"
                  Target="[INSTALLDIR]Prizrak-Box.exe"
                  WorkingDirectory="INSTALLDIR"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
        <RemoveFolder Id="RemoveDesktopFolder" On="uninstall" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu Shortcut -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="$(var.StartMenuShortcutGuid)">
        <Shortcut Id="StartMenuShortcut"
                  Name="$(var.ProductName)"
                  Description="!(loc.PB_ProductDescription)"
                  Target="[INSTALLDIR]Prizrak-Box.exe"
                  WorkingDirectory="INSTALLDIR"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      </Component>
    </DirectoryRef>

    <!-- Custom Actions -->

    <!-- Stop processes and services BEFORE installation -->
    <CustomAction Id="StopProcessesBeforeInstall"
                  Directory="TARGETDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = &apos;SilentlyContinue&apos;; Get-Process -Name Prizrak-Box,px,px-service | Stop-Process -Force; $svc = Get-Service PrizrakBoxService; if ($svc) { if ($svc.Status -eq &apos;Running&apos;) { Stop-Service PrizrakBoxService -Force }; sc.exe delete PrizrakBoxService | Out-Null }"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Install TUN Service AFTER files are installed -->
    <CustomAction Id="InstallTunService"
                  Directory="RESOURCESDIR"
                  ExeCommand='"[RESOURCESDIR]px-service.exe" -install'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Stop processes and services BEFORE uninstallation -->
    <CustomAction Id="StopProcessesBeforeUninstall"
                  Directory="TARGETDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = &apos;SilentlyContinue&apos;; Get-Process -Name Prizrak-Box,px,px-service | Stop-Process -Force; $svc = Get-Service PrizrakBoxService; if ($svc) { if ($svc.Status -eq &apos;Running&apos;) { Stop-Service PrizrakBoxService -Force }; sc.exe delete PrizrakBoxService | Out-Null }"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <?ifdef Wails ?>
    <!-- Best-effort removal of an old per-user Squirrel install (the v1.0.20
         windows-*-Setup.exe, installed to %LOCALAPPDATA%\Prizrak-Box). Runs
         impersonated so %LOCALAPPDATA% resolves to the installing user; a
         per-machine MSI cannot reliably reach another account's profile, so
         failures are ignored (best-effort, as agreed). -->
    <CustomAction Id="UninstallSquirrel"
                  Directory="TARGETDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = &apos;SilentlyContinue&apos;; $root = Join-Path $env:LOCALAPPDATA &apos;Prizrak-Box&apos;; $upd = Join-Path $root &apos;Update.exe&apos;; if (Test-Path $upd) { Start-Process -FilePath $upd -ArgumentList &apos;--uninstall&apos;,&apos;-s&apos; -Wait; Remove-Item -LiteralPath $root -Recurse -Force }"'
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <!-- Safety net for the leftover Electron install directory. RemoveExisting-
         Products normally clears it, but the electron-forge build lives in
         "Program Files (x86)\Prizrak-Box" (x86) while the Wails MSI installs to
         "Program Files\Prizrak-Box" (x64); this scrubs any orphaned Electron
         folder in either location. It only deletes a folder that carries the
         electron-forge signature (.installInfo.json or an app-* subdir) — the
         Wails layout has neither, and user data lives in %APPDATA%, so nothing
         of value is touched. -->
    <CustomAction Id="CleanupLegacyElectron"
                  Directory="TARGETDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = &apos;SilentlyContinue&apos;; foreach ($base in @(${env:ProgramFiles(x86)}, $env:ProgramFiles)) { if (-not $base) { continue }; $d = Join-Path $base &apos;Prizrak-Box&apos;; if (Test-Path $d) { $isElectron = (Test-Path (Join-Path $d &apos;.installInfo.json&apos;)) -or (Get-ChildItem -LiteralPath $d -Directory -Filter &apos;app-*&apos; -ErrorAction SilentlyContinue); if ($isElectron) { Remove-Item -LiteralPath $d -Recurse -Force } } }"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    <?endif?>

    <!-- Installation Sequence -->
    <InstallExecuteSequence>
      <!-- Stop processes/services before installing files -->
      <Custom Action="StopProcessesBeforeInstall" Before="InstallFiles">
        NOT REMOVE
      </Custom>

      <?ifdef Wails ?>
      <!-- After RemoveExistingProducts (removes the Electron MSI) and before the
           new files are installed, mop up a per-user Squirrel install and any
           orphaned Electron directory. -->
      <Custom Action="UninstallSquirrel" After="RemoveExistingProducts">
        NOT REMOVE
      </Custom>
      <Custom Action="CleanupLegacyElectron" After="UninstallSquirrel">
        NOT REMOVE
      </Custom>
      <?endif?>

      <!-- Install TUN Service after files (if feature selected) -->
      <Custom Action="InstallTunService" After="InstallFiles">
        <![CDATA[NOT REMOVE AND &TUNServiceFeature=3]]>
      </Custom>

      <!-- Stop processes/services before removing files -->
      <Custom Action="StopProcessesBeforeUninstall" Before="RemoveFiles">
        <![CDATA[REMOVE="ALL"]]>
      </Custom>
    </InstallExecuteSequence>

    <!-- Reference Custom UI -->
    <UIRef Id="CustomUI" />

    <!-- Features -->
    <Feature Id="MainApplication"
             Title="!(loc.PB_FeatureMainTitle)"
             Description="!(loc.PB_FeatureMainDescription)"
             Level="1"
             Display="expand"
             ConfigurableDirectory="INSTALLDIR"
             AllowAdvertise="no"
             Absent="disallow">
      <ComponentRef Id="AppRegistration" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentGroupRef Id="ApplicationFiles" />
    </Feature>

    <Feature Id="TUNServiceFeature"
             Title="!(loc.PB_FeatureTUNTitle)"
             Description="!(loc.PB_FeatureTUNDescription)"
             Level="1"
             AllowAdvertise="no">
      <!-- TUN service will be installed by CustomAction -->
      <ComponentGroupRef Id="TUNServiceFiles" />
    </Feature>

  </Product>
</Wix>
